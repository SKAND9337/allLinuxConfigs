{
  "files.autoSave": "onWindowChange",
  "code-runner.saveAllFilesBeforeRun": true,
  "git.autofetch": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorBlinking": "expand",
  "editor.fontSize": 16,
  "editor.fontFamily": "'Fira Code', 'Geist Mono'",
  "editor.formatOnSave": true,
  "terminal.integrated.fontFamily": "monospace",
  "workbench.iconTheme": "vscode-icons",
  "workbench.productIconTheme": "el-vsc-v1-icons",
  "workbench.colorTheme": "archangel",
  "code-runner.runInTerminal": true,
  "code-runner.saveFileBeforeRun": true,
  "code-runner.fileDirectoryAsCwd": true,
  "code-runner.executorMap": {
    "cpp": "clear && g++ -std=c++23 -O2 $fileName -o $fileNameWithoutExt && time ./$fileNameWithoutExt",
    "java": "clear && javac $fileName && java $fileNameWithoutExt",
    "python": "clear && python $fileName"
  },
  "vsicons.dontShowNewVersionMessage": true,
  "editor.lineNumbers": "relative",
  "jdk.telemetry.enabled": false,
  "C_Cpp.intelliSenseEngine": "disabled",
  "vim.useSystemClipboard": true,
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.ignorecase": true,
  "vim.smartcase": true,
  "vim.leader": " ",
  "editor.fontLigatures": false,
  "terminal.integrated.allowChords": false,
  "telemetry.feedback.enabled": false,
  "telemetry.editStats.enabled": false,
  "telemetry.telemetryLevel": "off",
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.enableKittyKeyboardProtocol": false,
  "update.showReleaseNotes": false,
}