/**
 * @name ClearVision V7 for BetterDiscord
 * @author ClearVision Team
 * @version 7.0.0
 * @description Highly customizable theme for BetterDiscord.
 * @source https://github.com/ClearVision/ClearVision-v7
 * @website https://clearvision.github.io
 * @invite dHaSxn3
 */
/* IMPORT CSS */
@import url("https://clearvision.github.io/ClearVision-v7/main.css");
@import url("https://clearvision.github.io/ClearVision-v7/vencord.css");
@import url('https://discordstyles.github.io/RadialStatus/RadialStatus.css');
@import url('https://fonts.googleapis.com/css2?family=quicksand:wght@100;300;400;500;700&display=swap');

/* SETTINGS */
:root {
  /* ACCENT COLORS */
  --main-color: #DC4F69;
  --hover-color: #79E158;
  --success-color: #38F19C;
  --danger-color: #E10505;
  /* STATUS COLORS */
  --online-color: #33FF31;
  --idle-color: #900bc8;
  --dnd-color: #F80E0E;
  --streaming-color: #5c4e75;
  --offline-color: #8D8D8D;
  /* APP BACKGROUND */
  --background-shading-percent: 100%;
  --background-image: url(https://i.pinimg.com/736x/81/80/8e/81808e28dadfdfb531dff9bb4536d976.jpg);
  --background-attachment: fixed;
  --background-filter:
       saturate(calc(var(--saturation-factor, 1)))
       brightness(1.85);
  /* USER POPOUT BACKGROUND */
  --user-popout-image: var(--background-image);
  --user-popout-attachment: var(--background-attachment);
  --user-popout-filter: var(--background-filter);
  /* USER MODAL BACKGROUND */
  --user-modal-image: var(--background-image);
  --user-modal-attachment: var(--background-attachment);
  --user-modal-filter: var(--background-filter);
  /* HOME ICON */
  --home-icon: url(data:image/png;base64,);
  --home-size: 42.5px;
  /* FONTS */
  --main-font: "Quicksand", Whitney, "Helvetica Neue", Helvetica, Arial, sans-serif;
  --code-font: Consolas, "Quicksand", "Quicksand", Menlo, Courier, monospace;

  /* Link text */
  :root{
      --url-color:#46FFF4;
  }
  
  --rs-small-spacing: 2.5px;
  --rs-medium-spacing: 2.5px;
  --rs-large-spacing: 2px;
  --rs-small-width: 2.0px;
  --rs-medium-width: 2.0px;
  --rs-large-width: 2.0px;
  --rs-avatar-shape: 100%;
  --rs-online-color: #33FF31;
  --rs-idle-color: #900bc8;
  --rs-dnd-color: #F80E0E;
  --rs-offline-color: #8D8D8D;
  --rs-streaming-color: #625775;
  --rs-phone-visible: block;
  /* Channel Colors */
  --channel-unread: #65FF4E;
  /* More options.... */
  --channel-color: rgb(255, 255, 255, 1);
  --channel-muted: rgb(182, 182, 182, 1);
  --channel-default: rgb(255, 255, 255, 1);
}

/* THEME SPECIFIC SHADING */
/* LIGHT THEME 
:is(.theme-light, .theme-dark .theme-light) {
  --background-shading: rgba(252, 252, 252, 0.3);
  --card-shading: rgba(252, 252, 252, 0.3);
  --popout-shading: rgba(252, 252, 252, 0.7);
  --modal-shading: rgba(252, 252, 252, 0.5);
  --input-shading: rgba(0, 0, 0, 0.3);
  --normal-text: #36363c;
  --muted-text: #75757e;
}*/

/* ASH THEME 
:is(.theme-dark, .theme-light .theme-dark) {
  --background-shading: rgba(0, 0, 0, 0.4);
  --card-shading: rgba(0, 0, 0, 0.2);
  --popout-shading: rgba(0, 0, 0, 0.6);
  --modal-shading: rgba(0, 0, 0, 0.4);
  --input-shading: rgba(255, 255, 255, 0.05);
  --normal-text: #d8d8db;
  --muted-text: #aeaeb4;
}*/

/* DARK THEME */
:is(.theme-darker, .theme-light .theme-darker) {
  --background-shading: rgba(0, 0, 0, 0.6);
  --card-shading: rgba(0, 0, 0, 0.3);
  --popout-shading: rgba(0, 0, 0, 0.7);
  --modal-shading: rgba(0, 0, 0, 0.5);
  --input-shading: rgba(255, 255, 255, 0.05);
  --normal-text: #fbfbfb;
  --muted-text: #94949c;
}

/* ONYX THEME 
:is(.theme-midnight, .theme-light .theme-midnight) {
  --background-shading: rgba(0, 0, 0, 0.8);
  --card-shading: rgba(0, 0, 0, 0.4);
  --popout-shading: rgba(0, 0, 0, 0.8);
  --modal-shading: rgba(0, 0, 0, 0.6);
  --input-shading: rgba(255, 255, 255, 0.05);
  --normal-text: #dcdcde;
  --muted-text: #86868e;
}*/

/* ADD ADDITIONAL CSS BELOW HERE */

:where(._68edb95846a37624-banner:not([style*="background-image"])) {
  background: none !important;
}

.c0bea05627c5dc35-outer:not(.custom-profile-theme) .c0bea05627c5dc35-inner {
  background: rgba(0, 0, 0, 0.712) !important;
}

.clickable__13533[aria-selected=true] .base__13533 {
  background-color: #dc4f69 !important;
}

.base__13533:hover {
  background-color: #dc4f69 !important;
}

/*Back/Forward Buttons*/
.backForwardButtons__63abb {
  display: none;
}

/* rotating oscillate animation */
@keyframes continuous-oscillate-rotate {
  0% {
    transform: rotate(0deg);
  }

  100% {
    transform: rotate(360deg);
  }
}

/* Rounding Off The Outer Edges Of The Nameplate */
.visual-refresh .container__37e49 {
  border-radius: 10px;
}

/* remove grabber from music player */
.grabber_a562c8 {
  visibility: hidden;
}

/*
  Makes the VenCord plugin's Shiki Code Blocks transparent
*/
.vc-shiki-container {
  background-color: rgba(0, 0, 0, 0.2) !important;
}

.rolePopout__75297 {
    background: rgba(0, 0, 0, 0.2) !important; 
    backdrop-filter: blur(8px) saturate(120%); 
    border: 1px solid rgba(255, 255, 255, 0.1); 
    border-radius: var(--radius-sm);
    box-shadow: var(--elevation-high);
    overflow: hidden;
}

/* 2. Inner Scroller: Remove background and border to fix "double frame" */
.roleScroller__75297 {
    background: transparent !important;
    border: none !important;
}

/* 3. Members & Hover: Basic styling */
.member__5d473.container__91a9d {
    margin: 2px 8px;
    border-radius: 4px;
}

.member__5d473.container__91a9d:hover {
    background: rgba(255, 255, 255, 0.05);
}

/* 4. Scrollbar: Keep it thin and themed */
.roleScroller__75297::-webkit-scrollbar { width: 4px; }
.roleScroller__75297::-webkit-scrollbar-thumb { 
    background: var(--main-color); 
    border-radius: 10px; 
}

/* 1. Global Glass Effect for Dropdowns, Menus, Search, and Popouts */
[role="menu"],
div[class^="menu_"],
div[class^="searchPopout_"],
div[class^="messagesPopoutWrap_"],
div[class^="recentMentionsPopout_"],
div[class^="browser_"],
div[class^="popout_"] {
    background: rgba(0, 0, 0, 0.2) !important; 
    backdrop-filter: blur(8px) saturate(120%); 
    border: 1px solid rgba(255, 255, 255, 0.1) !important; 
    border-radius: var(--radius-sm, 8px) !important;
    box-shadow: var(--elevation-high) !important;
}

/* 2. Remove Internal Backgrounds to Fix "Double Frame" */
/* This targets the inner scrollers of all the above elements */
[role="menu"] [class^="scroller_"],
div[class^="searchPopout_"] [class^="scroller_"],
div[class^="messagesPopoutWrap_"] [class^="scroller_"],
div[class^="recentMentionsPopout_"] [class^="scroller_"],
div[class^="popout_"] [class^="scroller_"] {
    background: transparent !important;
    border: none !important;
}

/* Fix inner headers/footers in pinned messages and inbox */
div[class^="messagesPopoutWrap_"] [class^="header_"],
div[class^="recentMentionsPopout_"] [class^="header_"],
div[class^="messagesPopoutWrap_"] [class^="footer_"] {
    background: transparent !important;
    border: none !important;
}

/* 3. Hover Effects for Menu Items & Search Results */
/* Right-click menu items */
[role="menu"] [class^="item_"]:hover,
[role="menu"] [class^="item_"][class*="focused_"] {
    background: rgba(255, 255, 255, 0.05) !important;
}

/* Search popout options */
div[class^="searchPopout_"] [class^="option_"]:hover,
div[class^="searchPopout_"] [class*="focused_"] {
    background: rgba(255, 255, 255, 0.05) !important;
}

/* Remove default background from search results groups */
div[class^="searchPopout_"] [class^="resultsGroup_"] {
    background: transparent !important;
}

/* Pinned messages and inbox message hover */
div[class^="messagesPopoutWrap_"] [class^="messageGroupWrapper_"]:hover,
div[class^="recentMentionsPopout_"] [class^="channelHeader_"]:hover {
    background: rgba(255, 255, 255, 0.05) !important;
}

/* Fix for the new Pinned Messages card layout */
div[class^="messagesPopoutWrap_"] div[class^="messageGroupWrapper_"] {
    background: rgba(0, 0, 0, 0.2) !important;
    border: 1px solid rgba(255, 255, 255, 0.05) !important;
}

/* Fix for the new Inbox / Mentions card layout */
div[class^="recentMentionsPopout_"] div[class^="container_"],
div[class^="recentMentionsPopout_"] [class^="channelHeader_"] {
    background: rgba(0, 0, 0, 0.2) !important;
    border: 1px solid rgba(255, 255, 255, 0.05) !important;
}

/* Optional: Subtle hover effect for the inbox cards so they feel interactive */
div[class^="recentMentionsPopout_"] div[class^="container_"]:hover {
    background: rgba(255, 255, 255, 0.05) !important;
}

/* --- Frosty Glass Fix for Server Popouts & Tooltips --- */
div[class*="guildPopout"],
div[class*="tooltip_"],
div[role="tooltip"] {
  background: var(--popout-shading) !important;
  /* Frosted glass for channel preview popouts */
  div[class*="popout_"][class*="layer"],
  div[class*="hover"] {
      background: rgba(0,0,0,.20) !important;
      backdrop-filter: blur(6px) saturate(120%);
      -webkit-backdrop-filter: blur(8px) saturate(120%);
  
      border: 1px solid rgba(255,255,255,.10) !important;
      border-radius: var(--radius-sm,8px);
      box-shadow: var(--elevation-high);
  }
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3) !important;
  border: 1px solid rgba(255, 255, 255, 0.08) !important;
}

/* Make sure the little pointer arrow matches the new glassy background */
div[class*="tooltipPointer_"] {
  border-top-color: var(--popout-shading) !important;
}

/* Hide solid inner backgrounds so the blur actually shows through */
div[class*="guildPopout"],
div[class*="tooltip_"],
div[role="tooltip"] {
    background: rgba(0,0,0,.20) !important;
    backdrop-filter: blur(8px) saturate(120%);
    -webkit-backdrop-filter: blur(8px) saturate(120%);

    border: 1px solid rgba(255,255,255,.08) !important;
    box-shadow: var(--elevation-high) !important;
}
